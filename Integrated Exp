package Integration_Exp;

import static org.junit.Assert.*;
import org.junit.Test;

public class EcommerceUnitTest {

    // Login validation
    public boolean login(String username, String password) {
        return username.equals("admin") && password.equals("1234");
    }

    // Cart total calculation
    public int cartTotal(int price, int quantity) {
        return price * quantity;
    }

    // Transaction validation
    public boolean transaction(double balance, double amount) {
        return balance >= amount;
    }

    @Test
    public void testLoginSuccess() {
        assertTrue(login("admin", "1234"));
    }

    @Test
    public void testLoginFailure() {
        assertFalse(login("user", "wrong"));
    }

    @Test
    public void testCartCalculation() {
        assertEquals(500, cartTotal(100, 5));
    }

    @Test
    public void testTransactionSuccess() {
        assertTrue(transaction(5000, 2000));
    }

    @Test
    public void testTransactionFailure() {
        assertFalse(transaction(1000, 2000));
    }
}
